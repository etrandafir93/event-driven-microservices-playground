{
  "title": "Slim Demo",
  "uid": "slimdemo",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1s",
  "time": {
    "from": "now-2m",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["200ms","500ms","1s","2s","5s","10s","30s","1m","5m","15m","30m","1h"]
  },
  "panels": [
    {
      "id": 100,
      "title": "HTTP / REST (Incoming)",
      "type": "row",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 30,
      "title": "Avg Response Time — Orders API (GET vs POST)",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 6, "x": 0, "y": 1},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(http_server_requests_milliseconds_sum{application=\"slimdemo\",uri=~\"/api/orders.*\",method=\"GET\"}[1m])) / sum(rate(http_server_requests_milliseconds_count{application=\"slimdemo\",uri=~\"/api/orders.*\",method=\"GET\"}[1m]))",
          "legendFormat": "GET /api/orders",
          "interval": "1s"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(http_server_requests_milliseconds_sum{application=\"slimdemo\",uri=~\"/api/orders.*\",method=\"POST\"}[1m])) / sum(rate(http_server_requests_milliseconds_count{application=\"slimdemo\",uri=~\"/api/orders.*\",method=\"POST\"}[1m]))",
          "legendFormat": "POST /api/orders",
          "interval": "1s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "id": 2,
      "title": "Latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 6, "x": 6, "y": 1},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_milliseconds_bucket{application=\"slimdemo\"}[1m])) by (le))",
          "legendFormat": "p50",
          "interval": "1s"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_milliseconds_bucket{application=\"slimdemo\"}[1m])) by (le))",
          "legendFormat": "p95",
          "interval": "1s"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_milliseconds_bucket{application=\"slimdemo\"}[1m])) by (le))",
          "legendFormat": "p99",
          "interval": "1s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "id": 1,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 6, "x": 12, "y": 1},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(http_server_requests_milliseconds_count{application=\"slimdemo\"}[1m])",
          "legendFormat": "{{method}} {{uri}} {{status}}",
          "interval": "1s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 31,
      "title": "Error Rate (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 6, "x": 18, "y": 1},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(http_server_requests_milliseconds_count{application=\"slimdemo\",status=~\"4..\"}[1m]))",
          "legendFormat": "4xx",
          "interval": "1s"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(http_server_requests_milliseconds_count{application=\"slimdemo\",status=~\"5..\"}[1m]))",
          "legendFormat": "5xx",
          "interval": "1s"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps"},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "4xx"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]
          },
          {
            "matcher": {"id": "byName", "options": "5xx"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]
          }
        ]
      }
    },

    {
      "id": 102,
      "title": "Database (HikariCP)",
      "type": "row",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 8}
    },
    {
      "id": 9,
      "title": "Connection Pool — Active / Idle / Pending",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 9},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "hikaricp_connections_active{application=\"slimdemo\"}",
          "legendFormat": "active",
          "interval": "1s"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "hikaricp_connections_idle{application=\"slimdemo\"}",
          "legendFormat": "idle",
          "interval": "1s"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "hikaricp_connections_pending{application=\"slimdemo\"}",
          "legendFormat": "pending",
          "interval": "1s"
        }
      ]
    },
    {
      "id": 10,
      "title": "Connection Acquire Time (avg)",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 9},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(hikaricp_connections_acquire_milliseconds_sum{application=\"slimdemo\"}[2m]) / rate(hikaricp_connections_acquire_milliseconds_count{application=\"slimdemo\"}[2m])",
          "legendFormat": "avg acquire ms",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms", "min": 0, "max": 200, "decimals": 0}}
    },
    {
      "id": 11,
      "title": "Connection Timeouts",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 9},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(hikaricp_connections_timeout_total{application=\"slimdemo\"}[1m])",
          "legendFormat": "timeouts/s",
          "interval": "1s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "cps", "color": {"fixedColor": "red", "mode": "fixed"}}}
    },

    {
      "id": 105,
      "title": "Loyalty Service (HTTP Client)",
      "type": "row",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 16}
    },
    {
      "id": 20,
      "title": "Call Rate",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 17},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(http_client_requests_milliseconds_count{application=\"slimdemo\",uri=\"/api/v2/loyalty/points\"}[1m])",
          "legendFormat": "{{method}} {{status}}",
          "interval": "1s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 21,
      "title": "Latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 17},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.50, sum(rate(http_client_requests_milliseconds_bucket{application=\"slimdemo\",uri=\"/api/v2/loyalty/points\"}[1m])) by (le))",
          "legendFormat": "p50",
          "interval": "1s"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.95, sum(rate(http_client_requests_milliseconds_bucket{application=\"slimdemo\",uri=\"/api/v2/loyalty/points\"}[1m])) by (le))",
          "legendFormat": "p95",
          "interval": "1s"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.99, sum(rate(http_client_requests_milliseconds_bucket{application=\"slimdemo\",uri=\"/api/v2/loyalty/points\"}[1m])) by (le))",
          "legendFormat": "p99",
          "interval": "1s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "id": 22,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 17},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(http_client_requests_milliseconds_count{application=\"slimdemo\",uri=\"/api/v2/loyalty/points\",outcome!=\"SUCCESS\"}[1m])",
          "legendFormat": "{{outcome}} {{status}}",
          "interval": "1s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"fixedColor": "red", "mode": "fixed"}}}
    },

    {
      "id": 103,
      "title": "Kafka Producer",
      "type": "row",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24}
    },
    {
      "id": 12,
      "title": "Records Sent / s",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 6, "x": 0, "y": 25},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "kafka_producer_record_send_rate{application=\"slimdemo\"}",
          "legendFormat": "{{client_id}}",
          "interval": "1s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 13,
      "title": "Record Error Rate",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 6, "x": 6, "y": 25},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "kafka_producer_record_error_rate{application=\"slimdemo\"}",
          "legendFormat": "{{client_id}}",
          "interval": "1s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"fixedColor": "red", "mode": "fixed"}}}
    },
    {
      "id": 14,
      "title": "Request Latency avg",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 6, "x": 12, "y": 25},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "kafka_producer_request_latency_avg{application=\"slimdemo\"}",
          "legendFormat": "{{client_id}}",
          "interval": "1s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "id": 15,
      "title": "Batch Size avg",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 6, "x": 18, "y": 25},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "kafka_producer_batch_size_avg{application=\"slimdemo\"}",
          "legendFormat": "{{client_id}}",
          "interval": "1s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },

    {
      "id": 101,
      "title": "JVM",
      "type": "row",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 32}
    },
    {
      "id": 5,
      "title": "Heap Used vs Committed",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 6, "x": 0, "y": 33},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "jvm_memory_used_bytes{application=\"slimdemo\",area=\"heap\"}",
          "legendFormat": "used {{id}}",
          "interval": "1s"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "jvm_memory_committed_bytes{application=\"slimdemo\",area=\"heap\"}",
          "legendFormat": "committed {{id}}",
          "interval": "1s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 6,
      "title": "Non-Heap (Metaspace etc.)",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 6, "x": 6, "y": 33},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "jvm_memory_used_bytes{application=\"slimdemo\",area=\"nonheap\"}",
          "legendFormat": "{{id}}",
          "interval": "1s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 7,
      "title": "GC Pause Rate",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 6, "x": 12, "y": 33},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(jvm_gc_pause_milliseconds_sum{application=\"slimdemo\"}[1m])",
          "legendFormat": "{{action}} {{cause}}",
          "interval": "1s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "id": 8,
      "title": "Threads",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 6, "x": 18, "y": 33},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "jvm_threads_live{application=\"slimdemo\"}",
          "legendFormat": "live",
          "interval": "1s"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "jvm_threads_daemon{application=\"slimdemo\"}",
          "legendFormat": "daemon",
          "interval": "1s"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "jvm_threads_peak{application=\"slimdemo\"}",
          "legendFormat": "peak",
          "interval": "1s"
        }
      ]
    },

    {
      "id": 104,
      "title": "Logs",
      "type": "row",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 40}
    },
    {
      "id": 19,
      "title": "Application Logs",
      "type": "logs",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 41},
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "{service_name=\"slimdemo\"}",
          "legendFormat": ""
        }
      ]
    }
  ]
}
